# ============================================================
# Auvvo AI — Configuracao de Ambiente (EXEMPLO)
# Copie para .env e preencha com seus valores reais.
# O arquivo .env NAO deve ser versionado (esta no .gitignore).
# ============================================================

# ============================================================
# BANCO DE DADOS (MySQL via XAMPP / Hostinger)
# ============================================================
DB_HOST=SEU_DB_HOST
DB_NAME=SEU_DB_NAME
DB_USER=SEU_DB_USER
DB_PASS=SUA_SENHA_DB

WORKER_HMAC_SECRET=SEU_HMAC_SECRET_AQUI
# ============================================================
# AMBIENTE DE EXECUCAO
# development → logs detalhados, erros na tela
# production  → erros silenciosos, logs em arquivo
# ============================================================
APP_ENV=production
APP_BASE_URL=https://seudominio.com

# ============================================================
# EVOLUTION API (WhatsApp — Evolution Go)
# Docs: https://docs.evolutionfoundation.com.br/evolution-go
# ============================================================
EVOLUTION_API_URL=https://sua-url-evolution.com
EVOLUTION_API_KEY=SUA_API_KEY_EVOLUTION

# Segredo do webhook — gerado com: openssl rand -hex 32
# Configure o mesmo valor no painel Evolution em "webhookSecret"
# IMPORTANTE: valor DIFERENTE do EVOLUTION_API_KEY
WEBHOOK_SECRET=SEU_WEBHOOK_SECRET_AQUI

# ============================================================
# DEEPSEEK API (alternativa ao OpenRouter — direto na API DeepSeek)
# Docs: https://platform.deepseek.com/api_keys
# Modelos: deepseek-chat (V3), deepseek-reasoner (R1)
# ============================================================
DEEPSEEK_API_KEY=SUA_API_KEY_DEEPSEEK
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============================================================
# OPENROUTER (acesso unificado a modelos de IA)
# Docs: https://openrouter.ai/docs/quickstart
# ============================================================
OPENROUTER_API_KEY=SUA_API_KEY_OPENROUTER

# Modelo padrao usado quando o agente nao tem modelo configurado.
# Exemplos: openai/gpt-4o-mini, google/gemini-flash-1.5, anthropic/claude-3-haiku
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# ============================================================
# GOOGLE GEMINI (opcional — use OpenRouter como alternativa)
# ============================================================
# GEMINI_API_KEY=

# ============================================================
# GOOGLE CALENDAR (OAuth 2.0 — agendamento automatico)
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=SEU_GOOGLE_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET
# GOOGLE_OAUTH_REDIRECT_URI=

# ============================================================
# E-MAIL TRANSACIONAL (SMTP)
# ============================================================
SUPPORT_EMAIL=seu@email.com
MAIL_FROM_EMAIL=seu@email.com
MAIL_FROM_NAME=Auvvo
SMTP_HOST=seu-smtp.exemplo.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=seu@email.com
SMTP_PASS=SUA_SENHA_SMTP

# ============================================================
# GATEWAY DE PAGAMENTO (AbacatePay)
# ============================================================
PAYMENT_GATEWAY=abacatepay

# AbacatePay
ABACATEPAY_API_KEY=SUA_API_KEY_ABACATEPAY
ABACATEPAY_PRODUCT_MENSAL=SEU_PRODUTO_MENSAL_ID
ABACATEPAY_PRODUCT_TRIMESTRAL=SEU_PRODUTO_TRIMESTRAL_ID
ABACATEPAY_PRODUCT_ANUAL=SEU_PRODUTO_ANUAL_ID
# Token de seguranca para o webhook (?webhookSecret=...)
ABACATEPAY_WEBHOOK_QUERY_SECRET=SEU_WEBHOOK_QUERY_SECRET

# ============================================================
# DIAGNOSTICO / LOGGING
# WEBHOOK_TRACE_LOG=1 → grava backend/webhook_trace.log (JSONL)
# ============================================================
WEBHOOK_TRACE_LOG=1

# Desabilita o worker CLI em background no LiteSpeed (use 1 apenas para debug)
# WEBHOOK_DISABLE_LITESPEED_CLI=0
WEBHOOK_LLM_CURL_TIMEOUT_SEC=240

PUBLIC_SUPPORT_WHATSAPP=558137711183

# Modo de processamento IA no webhook
WEBHOOK_AI_MODE=queue
WEBHOOK_DEBOUNCE_SEC=4
