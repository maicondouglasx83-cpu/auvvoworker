# =============================================================
# auvvo-worker — variáveis de ambiente para Docker na VPS
# Copie para .env.worker e preencha. NUNCA versione .env.worker!
# =============================================================

# -------------------------------------------------------
# BANCO DE DADOS
# Hostinger shared hosting: veja em hPanel > MySQL Databases
# Host geralmente é: mysql.hostinger.com ou o IP externo
# -------------------------------------------------------
DB_HOST=212.85.3.45
DB_NAME=u123456789_auvvo
DB_USER=u123456789_auvvo
DB_PASS=6BgE8R4?HT:+

# -------------------------------------------------------
# URL PÚBLICA DO APP PHP (shared hosting)
# O worker chama o PHP por HTTP para processar jobs de IA
# IMPORTANTE: deve ser a URL pública, não localhost
# -------------------------------------------------------
APP_BASE_URL=https://auvvo.com

# Se o PHP estiver num subdiretório (ex: dominio.com/auvvo/)
# APP_HTTP_PREFIX=auvvo

# -------------------------------------------------------
# FILA E PERFORMANCE
# -------------------------------------------------------
WEBHOOK_AI_MODE=queue
WORKER_POLL_MS=500
WORKER_AI_MAX_ATTEMPTS=5
CAMPAIGN_MSGS_PER_MINUTE=12

# -------------------------------------------------------
# HEARTBEAT — caminho dentro do container
# Não altere a menos que saiba o que está fazendo
# -------------------------------------------------------
AUVVO_WORKER_HEARTBEAT=/app/storage/worker_heartbeat.txt

WORKER_HMAC_SECRET=AUVVO-INTERNAL-WORKER-V1